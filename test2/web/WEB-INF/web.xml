<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- 欢迎页面：访问项目根路径时自动跳转到 score.html -->
    <welcome-file-list>
        <welcome-file>score.html</welcome-file>
    </welcome-file-list>

    <!--
        Servlet 映射说明：
        本项目使用 @WebServlet 注解配置（见 ScoreServlet.java），
        因此此处无需再手动配置 <servlet> 和 <servlet-mapping>。
        如果你的 Tomcat 版本不支持注解，可取消下方注释手动配置：
    -->
    <!--
    <servlet>
        <servlet-name>ScoreServlet</servlet-name>
        <servlet-class>com.score.ScoreServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ScoreServlet</servlet-name>
        <url-pattern>/ScoreServlet</url-pattern>
    </servlet-mapping>
    -->

</web-app>
