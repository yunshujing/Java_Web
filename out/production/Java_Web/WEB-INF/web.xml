<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ==================== 过滤器配置 ==================== -->

    <!--
        中文乱码过滤器
        对所有请求统一设置UTF-8编码，解决中文乱码问题
        注意：本项目使用 @WebFilter 注解配置（见 EncodingFilter.java）
        如果 Tomcat 版本不支持注解，可取消下方注释手动配置：
    -->
    <!--
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.login.filter.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    -->

    <!--
        自动登录过滤器
        在用户未登录时，检查自动登录Cookie并自动恢复登录状态
        注意：本项目使用 @WebFilter 注解配置（见 AutoLoginFilter.java）
        如果 Tomcat 版本不支持注解，可取消下方注释手动配置：
    -->
    <!--
    <filter>
        <filter-name>AutoLoginFilter</filter-name>
        <filter-class>com.login.filter.AutoLoginFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AutoLoginFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    -->

    <!-- ==================== Servlet配置 ==================== -->

    <!--
        Servlet 映射说明：
        本项目使用 @WebServlet 注解配置（见 LoginServlet.java、LogoutServlet.java），
        因此此处无需再手动配置 <servlet> 和 <servlet-mapping>。
        如果你的 Tomcat 版本不支持注解，可取消下方注释手动配置：
    -->
    <!--
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.login.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.login.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>
    -->

    <!-- ==================== 欢迎页面 ==================== -->

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
